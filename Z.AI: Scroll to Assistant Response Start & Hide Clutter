// ==UserScript==
// @name         Z.AI: Scroll to Assistant Response Start & Hide Clutter
// @namespace    http://tampermonkey.net/
// @version      1.2
// @description  Кнопка прокрутки к началу последнего ответа ИИ + скрытие дисклеймеров и промо-баннера на chat.z.ai
// @match        https://chat.z.ai/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    // ========== 1. СКРЫВАЕМ НЕЖЕЛАТЕЛЬНЫЕ ЭЛЕМЕНТЫ (CSS) ==========
    const style = document.createElement('style');
    style.textContent = `
        /* 1. Скрываем дисклеймеры по классам */
        .disclaimer,
        [class*="disclaimer"],
        [class*="warning"],
        [data-testid*="disclaimer"] {
            display: none !important;
        }
    `;
    document.head.appendChild(style);

    // ========== 2. ФУНКЦИЯ СКРЫТИЯ ПРОМО-БАННЕРА (по тексту) ==========
    function hidePromoBanner() {
        // Ищем элемент с текстом "New product launched"
        const elements = document.querySelectorAll('div, span, a');
        for (const el of elements) {
            if (el.textContent && el.textContent.includes('New product launched')) {
                // Находим родительский блок .p-4.pt-2
                const parent = el.closest('.p-4.pt-2');
                if (parent) {
                    parent.style.display = 'none';
                    return; // Нашли и скрыли — выходим
                }
            }
        }
        // Если не нашли по тексту, пробуем другой подход: ищем блок с кнопкой-крестиком внутри
        const containers = document.querySelectorAll('.p-4.pt-2');
        for (const container of containers) {
            const button = container.querySelector('button.absolute.top-2.right-2');
            if (button && button.querySelector('svg')) {
                container.style.display = 'none';
            }
        }
    }

    // Запускаем при загрузке
    hidePromoBanner();

    // ========== 3. СКРЫТИЕ ДИСКЛЕЙМЕРОВ (по тексту) ==========
    function hideDisclaimerByText() {
        const phrases = [
            'может ошибаться',
            'AI can make mistakes',
            'проверьте важную информацию',
            'check important info',
            'сгенерировано ИИ',
            'generated by AI',
            'only for reference',
            'только для справки'
        ];
        document.querySelectorAll('div, span, p, footer').forEach(el => {
            const text = el.textContent || '';
            if (phrases.some(phrase => text.includes(phrase))) {
                if (!el.closest('.chat-assistant')) {
                    el.style.display = 'none';
                }
            }
        });
    }

    hideDisclaimerByText();

    // ========== 4. НАБЛЮДАТЕЛЬ ЗА ИЗМЕНЕНИЯМИ ==========
    const observer = new MutationObserver(() => {
        hidePromoBanner();
        hideDisclaimerByText();
    });
    observer.observe(document.body, { childList: true, subtree: true });

    // ========== 5. ПОИСК ПОСЛЕДНЕГО СООБЩЕНИЯ АССИСТЕНТА ==========
    function getLastAssistantMessage() {
        const messageBlocks = document.querySelectorAll('div[id^="message-"]');
        for (let i = messageBlocks.length - 1; i >= 0; i--) {
            const block = messageBlocks[i];
            if (block.querySelector('.chat-assistant')) {
                return block;
            }
        }
        const assistants = document.querySelectorAll('.chat-assistant');
        if (assistants.length > 0) {
            return assistants[assistants.length - 1].closest('div[id^="message-"]') || assistants[assistants.length - 1];
        }
        return null;
    }

    // ========== 6. КНОПКА ==========
    const btn = document.createElement('button');
    btn.textContent = 'К началу ответа';
    btn.title = 'Прокрутить к началу последнего ответа ИИ';
    btn.style.cssText = `
        position: fixed;
        bottom: 28px;
        right: 28px;
        z-index: 10000;
        padding: 10px 18px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        box-shadow: 0 4px 14px rgba(102, 126, 234, 0.35);
        transition: all 0.2s ease;
        backdrop-filter: blur(6px);
    `;

    btn.onmouseenter = () => {
        btn.style.transform = 'translateY(-2px)';
        btn.style.boxShadow = '0 6px 18px rgba(102, 126, 234, 0.5)';
    };
    btn.onmouseleave = () => {
        btn.style.transform = 'translateY(0)';
        btn.style.boxShadow = '0 4px 14px rgba(102, 126, 234, 0.35)';
    };

    btn.onclick = () => {
        const target = getLastAssistantMessage();
        if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            const origBorder = target.style.borderTop;
            const origTrans = target.style.transition;
            target.style.transition = 'border-top 0.2s ease';
            target.style.borderTop = '3px solid #667eea';
            setTimeout(() => {
                target.style.borderTop = origBorder;
                target.style.transition = origTrans;
            }, 1500);
        } else {
            console.warn('[Z.AI Scroll] Assistant message not found');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    };

    // ========== 7. ДОБАВЛЕНИЕ КНОПКИ ==========
    function initButton() {
        if (document.body) {
            document.body.appendChild(btn);
        } else {
            setTimeout(initButton, 100);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initButton);
    } else {
        initButton();
    }

    // ========== 8. ПОДДЕРЖКА НАВИГАЦИИ В SPA ==========
    let lastUrl = location.href;
    new MutationObserver(() => {
        const url = location.href;
        if (url !== lastUrl) {
            lastUrl = url;
            if (!document.body.contains(btn)) {
                initButton();
            }
        }
    }).observe(document, { subtree: true, childList: true });
})();
