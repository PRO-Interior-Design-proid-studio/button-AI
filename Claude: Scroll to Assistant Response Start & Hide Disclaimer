// ==UserScript==
// @name         Claude: Scroll to Assistant Response Start & Hide Disclaimer
// @namespace    http://tampermonkey.net/
// @version      1.1
// @description  Кнопка прокрутки к началу последнего ответа ИИ + скрытие дисклеймера, иконки и пустого блока на claude.ai
// @match        https://claude.ai/*
// @match        https://chat.claude.ai/*
// @grant        none
// @run-at       document-idle
// ==/UserScript==

(function() {
    'use strict';

    // ========== 1. СКРЫВАЕМ НЕЖЕЛАТЕЛЬНЫЕ ЭЛЕМЕНТЫ ==========
    const style = document.createElement('style');
    style.textContent = `
        /* 1. Скрываем дисклеймер Claude */
        div[role="note"][data-disclaimer="true"] {
            display: none !important;
        }

        /* 2. Скрываем иконку (брендинг/логотип) */
        div.ml-1.mt-6.flex.items-center:has(div.w-8.text-accent-brand.inline-block.select-none) {
            display: none !important;
        }

        /* 3. Скрываем пустой блок h-12 после иконки */
        div.h-12:has(+ div.h-12) {
            display: none !important;
        }
        /* Или скрыть любой пустой h-12, который идёт после иконки */
        /* Но безопаснее: скрываем только h-12, который находится рядом */
        div.h-12:first-of-type {
            display: none !important;
        }
    `;
    document.head.appendChild(style);

    // ========== 2. ПОИСК ПОСЛЕДНЕГО СООБЩЕНИЯ ==========
    function getLastAssistantMessage() {
        const groups = document.querySelectorAll('div.group:has(div[data-is-streaming="false"])');
        if (groups.length > 0) {
            return groups[groups.length - 1];
        }
        const containers = document.querySelectorAll('div[data-is-streaming="false"]');
        if (containers.length > 0) {
            return containers[containers.length - 1];
        }
        return null;
    }

    // ========== 3. КНОПКА ==========
    const btn = document.createElement('button');
    btn.textContent = 'К началу ответа';        // ← Меняйте текст
    btn.title = 'Прокрутить к началу последнего ответа ИИ';
    btn.style.cssText = `
        position: fixed;
        bottom: 28px;                          /* ← Отступ снизу */
        right: 28px;                           /* ← Отступ справа */
        z-index: 10000;
        padding: 10px 18px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* ← Цвета */
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        box-shadow: 0 4px 14px rgba(102, 126, 234, 0.35);
        transition: all 0.2s ease;
        backdrop-filter: blur(6px);
    `;

    btn.onmouseenter = () => {
        btn.style.transform = 'translateY(-2px)';
        btn.style.boxShadow = '0 6px 18px rgba(102, 126, 234, 0.5)';
    };
    btn.onmouseleave = () => {
        btn.style.transform = 'translateY(0)';
        btn.style.boxShadow = '0 4px 14px rgba(102, 126, 234, 0.35)';
    };

    btn.onclick = () => {
        const target = getLastAssistantMessage();
        if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // Подсветка верхней границы
            const origBorder = target.style.borderTop;
            const origTrans = target.style.transition;
            target.style.transition = 'border-top 0.2s ease';
            target.style.borderTop = '3px solid #667eea';
            setTimeout(() => {
                target.style.borderTop = origBorder;
                target.style.transition = origTrans;
            }, 1500);
        } else {
            console.warn('[Claude Scroll] Assistant message not found');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    };

    // ========== 4. ДОБАВЛЕНИЕ ==========
    function initButton() {
        if (document.body) {
            document.body.appendChild(btn);
        } else {
            setTimeout(initButton, 100);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initButton);
    } else {
        initButton();
    }

    // ========== 5. ПОДДЕРЖКА SPA ==========
    let lastUrl = location.href;
    new MutationObserver(() => {
        const url = location.href;
        if (url !== lastUrl) {
            lastUrl = url;
            if (!document.body.contains(btn)) {
                initButton();
            }
        }
    }).observe(document, { subtree: true, childList: true });
})();
